stdout=serial
usbnet_devaddr=f8:dc:7a:00:00:02
usbnet_hostaddr=f8:dc:7a:00:00:01
serverip=192.168.7.1
ipaddr=192.168.7.2
bootargs=console=ttySTM0,115200 debug ignore_loglevel earlycon \
         root=/dev/nfs nfsroot=192.168.7.1:/srv/nfs/,v4,tcp rw rootwait \
	 ip=192.168.7.2::192.168.7.1:255.255.255.0::usb0:off \
	 g_ether.host_addr=f8:dc:7a:00:00:01 \
	 g_ether.dev_addr=f8:dc:7a:00:00:02
bootcmd=if test $boot_device = "mmc"; then \
	   echo "Micro sd card boot" ;\
	   load mmc 0:4 0xC0200000 /zImage ;\
	   load mmc 0:4 0xC2400000 /ebook-reader.dtb ;\
	fi ;\
        if test $boot_device = "usb"; then \
	   echo "USB boot" ;\
           setenv dfu_alt_info "boot part 0 4" ;\
           dfu 0 mmc 0 ;\
	   load mmc 0:4 0xC0200000 /zImage ;\
	   load mmc 0:4 0xC2400000 /ebook-reader.dtb ;\
	fi ;\
	bind /soc/bus@5c007000/usb@49000000 usb_ether ;\
	bootz 0xC0200000 - 0xC2400000
ethact=usb_ether
