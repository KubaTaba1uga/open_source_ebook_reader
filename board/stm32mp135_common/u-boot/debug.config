CONFIG_LOCALVERSION="ebook_reader_debug"
# Can increase to 7
CONFIG_LOG_DEFAULT_LEVEL=3
# Can increase to 7
CONFIG_LOG_MAX_LEVEL=3
# CONFIG_DEBUG_UART_STM32=y
# CONFIG_DEBUG_UART=y
# CONFIG_DEBUG_DRIVER=y
# CONFIG_DEBUG_DEVRES=y
CONFIG_LOGF_FILE=y
CONFIG_LOGF_LINE=y
CONFIG_LOGF_FUNC=y
CONFIG_LOG=y
CONFIG_DEBUG=y
CONFIG_DEBUG_INFO=y
CONFIG_DEFAULT_ENV_FILE="board/st/stm32mp1/debug.env"
# Configure usb as ethernet interface
CONFIG_CMD_BIND=y
CONFIG_USB_ETHER=y
CONFIG_USB_ETH_CDC=y
CONFIG_USB_ETH_RNDIS=n
CONFIG_USBNET_DEV_ADDR="de:ad:be:ef:00:01"
CONFIG_USBNET_HOST_ADDR="de:ad:be:ef:00:00"
